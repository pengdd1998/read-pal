# read-pal Server Environment Variables
# Copy this file to .env and fill in your values.

# ── Database ──────────────────────────────────────────────
DB_HOST=localhost
DB_PORT=5432
DB_NAME=readpal
DB_USER=readpal
DB_PASSWORD=changeme

# ── Redis ─────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ── GLM AI (Zhipu) ────────────────────────────────────────
GLM_API_KEY=your-glm-api-key
GLM_BASE_URL=https://open.bigmodel.cn/api/paas/v4
DEFAULT_MODEL=glm-4.7-flash

# ── JWT ───────────────────────────────────────────────────
JWT_SECRET=generate-a-random-32-char-secret
JWT_EXPIRES_IN=7d

# ── Pinecone (optional — vector search) ───────────────────
# PINECONE_API_KEY=

# ── App ───────────────────────────────────────────────────
APP_ENV=development
FRONTEND_URL=http://localhost:3000

# ── SMTP (optional — password reset emails) ───────────────
# When unset, reset links are logged to console instead of emailed.
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_USER=
# SMTP_PASSWORD=
# SMTP_FROM=noreply@example.com
