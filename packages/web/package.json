{
  "name": "@read-pal/web",
  "version": "1.0.0",
  "private": true,
  "browserslist": [
    "> 1%",
    "last 2 versions",
    "not dead",
    "not ie 11"
  ],
  "scripts": {
    "dev": "next dev",
    "build": "next build && cp -r .next/static .next/standalone/packages/web/.next/static && cp -r public .next/standalone/packages/web/public 2>/dev/null; true",
    "start": "next start",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "clean": "rm -rf .next node_modules"
  },
  "dependencies": {
    "@read-pal/shared": "workspace:*",
    "axios": "^1.15.0",
    "dompurify": "^3.3.3",
    "next": "^14.0.0",
    "next-intl": "^4.9.1",
    "prismjs": "^1.30.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@tailwindcss/typography": "^0.5.19",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/dompurify": "^3.2.0",
    "@types/node": "^20.10.0",
    "@types/prismjs": "^1.26.6",
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^6.0.1",
    "autoprefixer": "^10.4.0",
    "jsdom": "^29.0.2",
    "postcss": "^8.5.9",
    "tailwindcss": "^3.3.0",
    "typescript": "^5.3.0",
    "vitest": "^4.1.4"
  }
}
