# read-pal Environment Variables Template
# Copy this file to .env and fill in your values

# ============================================================================
# API Configuration
# ============================================================================
API_PORT=3001
API_URL=http://localhost:3001
API_ENV=development

# ============================================================================
# Database (PostgreSQL)
# ============================================================================
DATABASE_URL=postgresql://user:password@localhost:5432/readpal
DATABASE_POOL_MIN=2
DATABASE_POOL_MAX=10

# ============================================================================
# Redis (Cache & Sessions)
# ============================================================================
REDIS_URL=redis://localhost:6379
REDIS_PASSWORD=
REDIS_DB=0

# ============================================================================
# Vector Database (Pinecone)
# ============================================================================
PINECONE_API_KEY=your-pinecone-api-key
PINECONE_ENVIRONMENT=us-east-1-aws
PINECONE_INDEX=readpal-vectors

# Alternative: Weaviate
# WEAVIATE_URL=http://localhost:8080
# WEAVIATE_API_KEY=

# ============================================================================
# Graph Database (Neo4j)
# ============================================================================
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=your-neo4j-password

# ============================================================================
# Claude AI (Anthropic)
# ============================================================================
ANTHROPIC_API_KEY=your-anthropic-api-key

# Model preferences (can be overridden per agent)
CLAUDE_MODEL_HAIKU=claude-3-5-haiku-20241022
CLAUDE_MODEL_SONNET=claude-3-5-sonnet-20241022
CLAUDE_MODEL_OPUS=claude-3-opus-20240229

# Agent settings
CLAUDE_MAX_TOKENS=4096
CLAUDE_TEMPERATURE=0.7
CLAUDE_TIMEOUT=30000

# ============================================================================
# Authentication
# ============================================================================
# Choose provider: auth0, clerk, custom
AUTH_PROVIDER=auth0

# Auth0
AUTH0_SECRET=your-auth0-secret
AUTH0_DOMAIN=your-domain.auth0.com
AUTH0_CLIENT_ID=your-auth0-client-id
AUTH0_CLIENT_SECRET=your-auth0-client-secret
AUTH0_CALLBACK_URL=http://localhost:3000/callback

# Clerk (alternative)
# CLERK_SECRET_KEY=your-clerk-secret-key
# CLERK_PUBLISHABLE_KEY=your-clerk-publishable-key

# JWT (for custom auth)
JWT_SECRET=your-jwt-secret
JWT_EXPIRES_IN=7d
JWT_REFRESH_EXPIRES_IN=30d

# ============================================================================
# File Storage (AWS S3)
# ============================================================================
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=your-aws-access-key
AWS_SECRET_ACCESS_KEY=your-aws-secret-key
S3_BUCKET=readpal-uploads
S3_CDN_URL=https://cdn.readpal.com

# ============================================================================
# Content Delivery (CloudFront)
# ============================================================================
CLOUDFRONT_DOMAIN=your-cloudfront-domain.cloudfront.net
CLOUDFRONT_KEY_PAIR_ID=your-key-pair-id
CLOUDFRONT_PRIVATE_KEY_PATH=/path/to/private-key.pem

# ============================================================================
# Analytics & Monitoring
# ============================================================================
# Mixpanel
MIXPANEL_TOKEN=your-mixpanel-token
MIXPANEL_API_HOST=https://api.mixpanel.com

# PostHog (alternative)
# POSTHOG_KEY=your-posthog-key
# POSTHOG_HOST=https://app.posthog.com

# Sentry (Error tracking)
SENTRY_DSN=your-sentry-dsn
SENTRY_ENVIRONMENT=development
SENTRY_TRACES_SAMPLE_RATE=0.1

# Datadog (Monitoring)
DATADOG_API_KEY=your-datadog-api-key
DATADOG_APP_KEY=your-datadog-app-key
DATADOG_SITE=datadoghq.com

# ============================================================================
# Email (SendGrid)
# ============================================================================
SENDGRID_API_KEY=your-sendgrid-api-key
SENDGRID_FROM_EMAIL=noreply@readpal.com
SENDGRID_FROM_NAME=read-pal

# AWS SES (alternative)
# AWS_SES_REGION=us-east-1
# AWS_SES_FROM_EMAIL=noreply@readpal.com

# ============================================================================
# Search (Algolia)
# ============================================================================
ALGOLIA_APP_ID=your-algolia-app-id
ALGOLIA_API_KEY=your-algolia-api-key
ALGOLIA_INDEX_NAME=readpal_library

# ============================================================================
# External APIs
# ============================================================================
# OpenAI (for additional AI capabilities)
OPENAI_API_KEY=your-openai-api-key

# Google Books API
GOOGLE_BOOKS_API_KEY=your-google-books-api-key

# Open Library API
OPEN_LIBRARY_BASE_URL=https://openlibrary.org

# Goodreads API
GOODREADS_API_KEY=your-goodreads-api-key
GOODREADS_API_SECRET=your-goodreads-api-secret

# ============================================================================
# OAuth Providers (for social login)
# ============================================================================
GOOGLE_OAUTH_CLIENT_ID=your-google-client-id
GOOGLE_OAUTH_CLIENT_SECRET=your-google-client-secret

GITHUB_OAUTH_CLIENT_ID=your-github-client-id
GITHUB_OAUTH_CLIENT_SECRET=your-github-client-secret

# ============================================================================
# Rate Limiting
# ============================================================================
RATE_LIMIT_ENABLED=true
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=100

# Agent-specific rate limits
AGENT_RATE_LIMIT_PER_MINUTE=60
AGENT_RATE_LIMIT_PER_HOUR=1000

# ============================================================================
# Feature Flags
# ============================================================================
FEATURE_READING_FRIEND=true
FEATURE_KNOWLEDGE_GRAPH=true
FEATURE_MEMORY_BOOKS=true
FEATURE_COLLABORATIVE_READING=false
FEATURE_EREADER_INTEGRATION=false

# ============================================================================
# AI Agent Settings
# ============================================================================
# Cost management
AGENT_MAX_COST_PER_USER=0.10
AGENT_DAILY_BUDGET=100.00

# Performance
AGENT_RESPONSE_TIMEOUT_MS=5000
AGENT_STREAM_RESPONSES=true

# Memory
AGENT_MEMORY_RETENTION_DAYS=365
AGENT_CONTEXT_WINDOW_SIZE=100

# ============================================================================
# Reading Friend Settings
# ============================================================================
FRIEND_DEFAULT_PERSONALITY=sage
FRIEND_INTERVENTION_STYLE=hybrid
FRIEND_QUIET_HOURS_START=22:00
FRIEND_QUIET_HOURS_END=08:00

# ============================================================================
# Content Processing
# ============================================================================
# Document parsing
PDF_MAX_SIZE_MB=50
EPUB_MAX_SIZE_MB=20
DOCX_MAX_SIZE_MB=10

# OCR
OCR_ENABLED=true
OCR_LANGUAGES=en,es,fr,de,zh

# Text extraction
TEXT_EXTRACTION_TIMEOUT_MS=30000

# ============================================================================
# Security
# ============================================================================
# CORS
CORS_ORIGIN=http://localhost:3000,http://localhost:19006
CORS_CREDENTIALS=true

# Content Security Policy
CSP_ENABLED=true

# Helmet (Express security headers)
HELMET_ENABLED=true

# Rate limiting by user
RATE_LIMIT_BY_USER=true

# ============================================================================
# Logging
# ============================================================================
LOG_LEVEL=debug
LOG_FORMAT=json
LOG_TO_FILE=true
LOG_FILE_PATH=./logs

# ============================================================================
# Development
# ============================================================================
NODE_ENV=development
DEBUG=readpal:*
HOT_RELOAD=true

# ============================================================================
# Testing
# ============================================================================
TEST_DATABASE_URL=postgresql://user:password@localhost:5432/readpal_test
TEST_REDIS_URL=redis://localhost:6379/1

# ============================================================================
# Docker
# ============================================================================
POSTGRES_PASSWORD=changeme
API_PORT=3001
WEB_PORT=3000

# ============================================================================
# Production Overrides
# ============================================================================
# When NODE_ENV=production, these override development settings
# NODE_ENV=production
# LOG_LEVEL=info
# DEBUG=
# HOT_RELOAD=false

# ============================================================================
# Third-party Services (Optional)
# ============================================================================
# Intercom (Customer support)
INTERCOM_APP_ID=your-intercom-app-id
INTERCOM_ACCESS_TOKEN=your-intercom-access-token

# Stripe (Payments)
STRIPE_PUBLIC_KEY=your-stripe-public-key
STRIPE_SECRET_KEY=your-stripe-secret-key
STRIPE_WEBHOOK_SECRET=your-stripe-webhook-secret
STRIPE_PRICE_ID_PREMIUM=your-price-id
STRIPE_PRICE_ID_TEAM=your-price-id

# ============================================================================
# Mobile App (React Native)
# ============================================================================
# Expo (for development)
EXPO_PROJECT_ID=@your-org/read-pal
EXPO_APPLE_APP_ID=com.readpal.app
EXPO_ANDROID_PACKAGE=com.readpal.app

# ============================================================================
# Infrastructure
# ============================================================================
# Terraform
TERRAFORM_VERSION=1.5.0
TERRAFORM_BUCKET=terraform-state-readpal
TERRAFORM_REGION=us-east-1

# Kubernetes
KUBERNETES_NAMESPACE=readpal
KUBERNETES_CLUSTER_NAME=readpal-cluster

# ============================================================================
# Miscellaneous
# ============================================================================
APP_NAME=read-pal
APP_VERSION=1.0.0
APP_URL=http://localhost:3000
API_URL=http://localhost:3001

# Support
SUPPORT_EMAIL=support@readpal.com
SUPPORT_URL=https://support.readpal.com

# Documentation
DOCS_URL=https://docs.readpal.com
API_DOCS_URL=https://docs.readpal.com/api

# Legal
PRIVACY_POLICY_URL=https://readpal.com/privacy
TERMS_OF_SERVICE_URL=https://readpal.com/terms
