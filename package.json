{
  "name": "read-pal",
  "version": "1.0.0",
  "private": true,
  "description": "AI agent-based reading companion application",
  "keywords": [
    "reading",
    "ai",
    "companion",
    "claude",
    "education"
  ],
  "author": "read-pal",
  "license": "PROPRIETARY",
  "scripts": {
    "dev": "turbo run dev --parallel",
    "dev:api": "pnpm --filter @read-pal/api dev",
    "dev:web": "pnpm --filter @read-pal/web dev",
    "dev:mobile": "pnpm --filter @read-pal/mobile dev",
    "dev:extension": "pnpm --filter @read-pal/extension dev",
    "build": "turbo run build",
    "build:api": "pnpm --filter @read-pal/api build",
    "build:web": "pnpm --filter @read-pal/web build",
    "build:mobile": "pnpm --filter @read-pal/mobile build",
    "build:extension": "pnpm --filter @read-pal/extension build",
    "test": "turbo run test",
    "test:watch": "turbo run test:watch --parallel",
    "test:coverage": "turbo run test:coverage",
    "test:unit": "turbo run test:unit",
    "test:integration": "turbo run test:integration",
    "test:e2e": "turbo run test:e2e",
    "lint": "turbo run lint",
    "lint:fix": "turbo run lint:fix",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json,md}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,js,jsx,json,md}\"",
    "typecheck": "turbo run typecheck",
    "clean": "turbo run clean && rm -rf node_modules",
    "setup": "pnpm install && pnpm build",
    "docker:up": "docker-compose up -d",
    "docker:down": "docker-compose down",
    "docker:logs": "docker-compose logs -f",
    "db:migrate": "pnpm --filter @read-pal/api db:migrate",
    "db:seed": "pnpm --filter @read-pal/api db:seed",
    "db:reset": "pnpm --filter @read-pal/api db:reset"
  },
  "devDependencies": {
    "@types/node": "^20.10.0",
    "@typescript-eslint/eslint-plugin": "^6.13.0",
    "@typescript-eslint/parser": "^6.13.0",
    "eslint": "^8.54.0",
    "eslint-config-prettier": "^9.0.0",
    "eslint-plugin-import": "^2.29.0",
    "prettier": "^3.8.2",
    "turbo": "^1.11.0",
    "typescript": "^5.3.0"
  },
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=8.0.0"
  },
  "packageManager": "pnpm@8.12.0"
}
