{
  "name": "read-pal",
  "version": "1.0.0",
  "private": true,
  "description": "AI reading companion — capture your reading journey as a personal book",
  "license": "PROPRIETARY",
  "scripts": {
    "dev": "pnpm --filter @read-pal/web dev",
    "build": "pnpm --filter @read-pal/shared build && NEXT_PUBLIC_API_URL= pnpm --filter @read-pal/web build",
    "build:web": "NEXT_PUBLIC_API_URL= pnpm --filter @read-pal/web build",
    "typecheck": "pnpm --filter @read-pal/web typecheck",
    "clean": "rm -rf packages/web/.next packages/shared/dist node_modules",
    "setup": "pnpm install && pnpm --filter @read-pal/shared build"
  },
  "devDependencies": {
    "@types/node": "^20.10.0",
    "typescript": "^5.3.0"
  },
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=8.0.0"
  },
  "packageManager": "pnpm@8.12.0"
}
